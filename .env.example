# Anthropic API key (required, no default) — read directly by the Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Self-consistency vote count (int >= 1). Default: 5
CLASSIFIER_N=5
# Sampling temperature (0.0–1.0). Default: 0.4
CLASSIFIER_TEMPERATURE=0.4
# Minimum confidence to accept a verdict (0.0–1.0). Default: 0.6
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
