# Inference provider: "anthropic" (first-party API) or "foundry" (Microsoft Foundry). Default: anthropic
CLASSIFIER_PROVIDER=anthropic

# --- provider: anthropic ---
# Anthropic API key (required when CLASSIFIER_PROVIDER=anthropic) — read directly by the Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model id override (optional). Default: claude-haiku-4-5
CLASSIFIER_ANTHROPIC_MODEL=claude-haiku-4-5

# --- provider: foundry ---
# Foundry resource name (required when CLASSIFIER_PROVIDER=foundry), e.g. my-resource
# for https://my-resource.services.ai.azure.com/anthropic/
ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource
# Foundry API key (optional). Omit to authenticate with managed identity / Entra ID.
ANTHROPIC_FOUNDRY_API_KEY=your-foundry-key-here
# Model id override (optional). Default: claude-haiku-4-5
CLASSIFIER_FOUNDRY_MODEL=claude-haiku-4-5
# Entra ID token scope for managed identity (optional). Default: https://cognitiveservices.azure.com/.default
CLASSIFIER_FOUNDRY_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# --- classifier knobs (provider-agnostic) ---
# Self-consistency vote count (int >= 1). Default: 5
CLASSIFIER_N=5
# Sampling temperature (0.0–1.0). Default: 0.4
CLASSIFIER_TEMPERATURE=0.4
# Minimum confidence to accept a verdict (0.0–1.0). Default: 0.6
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6
