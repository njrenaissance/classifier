# Inference provider: "anthropic" (first-party API) or "foundry" (Microsoft Foundry). Default: anthropic
CLASSIFIER_PROVIDER=anthropic

# --- provider: anthropic ---
# Anthropic API key (required when CLASSIFIER_PROVIDER=anthropic) — read directly by the Anthropic SDK.
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Model id override (optional). Default: claude-haiku-4-5
CLASSIFIER_ANTHROPIC_MODEL=claude-haiku-4-5

# --- provider: foundry ---
# Foundry resource name (required when CLASSIFIER_PROVIDER=foundry), e.g. my-resource
# for https://my-resource.services.ai.azure.com/anthropic/
ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource
# Authentication mode (choose one when CLASSIFIER_PROVIDER=foundry):
#   - set CLASSIFIER_FOUNDRY_USE_MANAGED_IDENTITY=true for managed identity / Entra ID (production), OR
#   - provide ANTHROPIC_FOUNDRY_API_KEY (leave the flag false/unset).
# Startup fails if neither is provided.
CLASSIFIER_FOUNDRY_USE_MANAGED_IDENTITY=false
ANTHROPIC_FOUNDRY_API_KEY=your-foundry-key-here
# Model id override (optional). Default: claude-haiku-4-5
CLASSIFIER_FOUNDRY_MODEL=claude-haiku-4-5
# Entra ID token scope for managed identity (optional). Default: https://cognitiveservices.azure.com/.default
CLASSIFIER_FOUNDRY_TOKEN_SCOPE=https://cognitiveservices.azure.com/.default

# --- classifier knobs (provider-agnostic) ---
# Self-consistency vote count (int >= 1). Default: 5
CLASSIFIER_N=5
# Sampling temperature (0.0–1.0). Default: 0.4
CLASSIFIER_TEMPERATURE=0.4
# Minimum confidence to accept a verdict (0.0–1.0). Default: 0.6
CLASSIFIER_CONFIDENCE_THRESHOLD=0.6

# --- cloud pipeline state store (ADR-0013) ---
# PostgreSQL connection URL. Required by the cloud path (walker/processor); the
# local CSV CLI does not use it.
CLASSIFIER__DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/classifier

# --- Microsoft Graph / SharePoint (ADR-0007/0015) ---
# App-only auth for the walker/processor. Choose one mode:
#   - set CLASSIFIER__GRAPH_USE_MANAGED_IDENTITY=true for managed identity / Entra ID (production), OR
#   - provide the client-credentials trio below (local dev / until a federated credential is configured).
# Startup fails if neither a managed identity nor the full trio is provided.
CLASSIFIER__GRAPH_USE_MANAGED_IDENTITY=false
CLASSIFIER__GRAPH_TENANT_ID=your-azure-ad-tenant-id
CLASSIFIER__GRAPH_CLIENT_ID=your-app-registration-client-id
CLASSIFIER__GRAPH_CLIENT_SECRET=your-app-registration-client-secret
# Graph token scope (optional). Default: https://graph.microsoft.com/.default
CLASSIFIER__GRAPH_TOKEN_SCOPE=https://graph.microsoft.com/.default
# Graph API base URL (optional). Default: https://graph.microsoft.com/v1.0
CLASSIFIER__GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# --- walker→processor work queue (ADR-0012/0014) ---
# Azure Queue Storage that decouples the two cloud jobs. The queue name is always
# required; choose one auth mode:
#   - provide CLASSIFIER__QUEUE_CONNECTION_STRING (local dev / Azurite), OR
#   - set CLASSIFIER__QUEUE_ACCOUNT_URL with CLASSIFIER__QUEUE_USE_MANAGED_IDENTITY=true (production).
# Startup fails if neither a connection string nor a managed-identity account URL is provided.
CLASSIFIER__QUEUE_NAME=classifier-work-items
CLASSIFIER__QUEUE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key
CLASSIFIER__QUEUE_USE_MANAGED_IDENTITY=false
CLASSIFIER__QUEUE_ACCOUNT_URL=https://your-account.queue.core.windows.net
